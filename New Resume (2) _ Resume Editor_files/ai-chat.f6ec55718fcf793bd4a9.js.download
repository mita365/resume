,wBAAA,CACA,kBAAA,CACA,kBAAA,CACA,aAAA,CACA,cAAA,CACA,gBAAA,CAGJ,mDACI,MAAA,CACA,WAAA,CAGJ,iDACI,aAAA,CACA,gBAAA,CACA,wBAAA,CACA,iBAAA,CACA,eAAA,CACA,aAAA,CACA,cAAA,CACA,eAAA,CACA,cAAA,CAEA,uDACI,oBAAA,CACA,kBAAA,CAIR,mCACI,YAAA,CACA,qBAAA,CACA,OAAA,CACA,gBAAA,CACA,mCAAA,CACA,kBAAA,CACA,kBAAA,CACA,cAAA,CAGJ,wCACI,uBAAA,CACA,eAAA,CACA,cAAA,CACA,wBAAA,CACA,mBAAA,CAGJ,uCACI,YAAA,CACA,kBAAA,CACA,6BAAA,CACA,OAAA,CACA,aAAA,CAGJ,uCACI,MAAA,CACA,eAAA,CACA,sBAAA,CACA,sBAAA,CACA,kBAAA,CAGJ,yCACI,YAAA,CACA,kBAAA,CACA,sBAAA,CACA,aAAA,CACA,UAAA,CACA,WAAA,CACA,SAAA,CACA,QAAA,CACA,iBAAA,CACA,sBAAA,CACA,uBAAA,CACA,cAAA,CACA,cAAA,CAEA,+CACI,0BAAA,CACA,sBAAA,CAIR,gCACI,YAAA,CACA,qBAAA,CACA,mBAAA,CACA,QAAA,CACA,qBAAA,CACA,YAAA,CACA,mCAAA,CACA,iBAAA,CACA,eAAA,CACA,oCAAA,CAGJ,4CACI,QAAA,CAGJ,4BACI,UAAA,CACA,eAAA,CACA,gBAAA,CACA,SAAA,CACA,QAAA,CACA,sBAAA,CACA,4BAAA,CACA,mBAAA,CACA,cAAA,CACA,gBAAA,CACA,WAAA,CACA,iBAAA,CACA,YAAA,CACA,8BAAA,CAEA,yCACI,uBAAA,CAIR,mCACI,YAAA,CACA,kBAAA,CACA,oBAAA,CACA,wBAAA,CACA,OAAA,CAGJ,gCACI,YAAA,CAGJ,iCACI,mBAAA,CACA,kBAAA,CACA,sBAAA,CACA,UAAA,CACA,WAAA,CACA,WAAA,CACA,QAAA,CACA,kBAAA,CACA,kBAAA,CACA,UAAA,CACA,cAAA,CACA,eAAA,CAEA,uCACI,kBAAA,CAGJ,0CACI,kBAAA,CACA,8BAAA,CACA,SAAA,CAIR,yBACI,gCACI,QAAA,CACA,YAAA,CAGJ,6BACI,SAAA,CAGJ,gCACI,YAAA,CAGJ,+BACI,cAAA,CAGJ,iCACI,cAAA,CAGJ,6CACI,UAAA,CACA,eAAA,CAGJ,kCACI,aAAA,CAGJ,qCACI,wBAAA,CAGJ,mCACI,kBAAA,CACA,UAAA,CAAA,CAIR,qCACI,YAAA,CACA,qBAAA,CACA,OAAA,CACA,UAAA,CACA,eAAA,CAGJ,uCACI,aAAA,CACA,WAAA,CACA,sBAAA,CACA,cAAA,CACA,eAAA,CACA,gBAAA,CAGJ,uCACI,YAAA,CACA,qBAAA,CACA,OAAA,CACA,aAAA,CAGJ,+CACI,YAAA,CACA,kBAAA,CACA,0BAAA,CACA,UAAA,CACA,eAAA,CACA,eAAA,CACA,wBAAA,CACA,iBAAA,CACA,eAAA,CACA,sBAAA,CACA,cAAA,CACA,eAAA,CACA,gBAAA,CACA,eAAA,CACA,cAAA,CAEA,qDACI,+BAAA,CACA,kBAAA",sourcesContent:['.container {\n    --chat-surface: #fff;\n    --chat-surface-strong: #fff;\n    --chat-border: #d8d9db;\n    --chat-border-strong: #c7ccd0;\n    --chat-text: #2d3639;\n    --chat-input-text: #384347;\n    --chat-muted: #60696c;\n    --chat-subtext: #afb4b5;\n    --chat-accent: #2dc08d;\n    --chat-accent-strong: #2dc08d;\n    --chat-accent-soft: #e3e9f5;\n    --chat-assistant: #e3e0f6;\n    --chat-assistant-strong: #e3e0f6;\n    --chat-warning-bg: #fff5d8;\n    --chat-warning-border: #f0db96;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    box-sizing: border-box;\n    width: 100%;\n    height: 100%;\n    max-height: 100%;\n    min-height: 0;\n    padding: 16px;\n    background: #fff;\n    overflow: hidden;\n}\n\n.containerCompact {\n    padding: 8px;\n}\n\n.header {\n    display: flex;\n    justify-content: flex-end;\n    min-height: 32px;\n    padding: 0;\n    border: 0;\n    background: transparent;\n    box-shadow: none;\n}\n\n.headerTop {\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    gap: 8px;\n}\n\n.headerControls {\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    gap: 6px;\n    width: auto;\n    max-width: 100%;\n    margin-left: auto;\n    min-width: 0;\n}\n\n.headerCopy {\n    min-width: 0;\n}\n\n.headerBadge {\n    display: inline-flex;\n    align-items: center;\n    padding: 4px 8px;\n    border-radius: 999px;\n    background: var(--chat-accent-soft);\n    color: var(--chat-accent);\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n}\n\n.title {\n    margin-top: 6px;\n    color: var(--chat-text);\n    font-size: 16px;\n    font-weight: 700;\n    line-height: 1.2;\n}\n\n.subtitle {\n    margin: 4px 0 0;\n    max-width: 230px;\n    color: var(--chat-muted);\n    font-size: 12px;\n    line-height: 1.45;\n}\n\n.modelSelect {\n    flex: 0 0 132px;\n    min-width: 0;\n    max-width: 100%;\n    height: 32px;\n    padding: 0 10px;\n    border: 1px solid var(--chat-border);\n    border-radius: 10px;\n    background: var(--chat-surface-strong);\n    color: var(--chat-text);\n    font-size: 12px;\n    font-weight: 600;\n    cursor: pointer;\n    outline: none;\n    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);\n\n    &:hover {\n        border-color: var(--chat-border-strong);\n    }\n\n    &:focus {\n        border-color: #a8ccbf;\n        box-shadow: 0 0 0 3px rgba(31, 127, 105, 0.12);\n    }\n\n    &:disabled {\n        opacity: 0.55;\n        cursor: not-allowed;\n    }\n}\n\n.headerMetaRow {\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    gap: 6px;\n}\n\n.statusPill {\n    display: inline-flex;\n    align-items: center;\n    min-height: 26px;\n    padding: 0 10px;\n    border-radius: 999px;\n    background: var(--chat-accent-soft);\n    color: var(--chat-accent);\n    font-size: 11px;\n    font-weight: 600;\n    line-height: 1;\n}\n\n.headerActions {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-left: auto;\n}\n\n.costBadgeWrapper {\n    position: relative;\n}\n\n.costBadge {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    min-width: 74px;\n    height: 32px;\n    padding: 0 10px;\n    border: 1px solid var(--chat-border);\n    border-radius: 10px;\n    background: var(--chat-surface-strong);\n    color: var(--chat-text);\n    font-size: 11px;\n    font-weight: 700;\n    cursor: pointer;\n    box-shadow: 0 2px 8px rgba(31, 49, 45, 0.04);\n\n    &:hover {\n        border-color: var(--chat-border-strong);\n        background: #fdfefd;\n    }\n}\n\n.costPopup {\n    position: absolute;\n    top: 38px;\n    right: 0;\n    min-width: 180px;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    padding: 12px 14px;\n    border: 1px solid var(--chat-border);\n    border-radius: 14px;\n    background: rgba(255, 255, 255, 0.98);\n    box-shadow: 0 14px 28px rgba(31, 49, 45, 0.12);\n    z-index: 2;\n}\n\n.costRow {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 18px;\n    color: var(--chat-text);\n    font-size: 13px;\n\n    span:first-child {\n        color: var(--chat-muted);\n    }\n\n    span:last-child {\n        font-weight: 600;\n        font-variant-numeric: tabular-nums;\n    }\n}\n\n.newChatButton {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    height: 32px;\n    padding: 0 12px;\n    border: 1px solid var(--chat-border);\n    border-radius: 10px;\n    background: var(--chat-surface-strong);\n    color: var(--chat-text);\n    font-size: 11px;\n    font-weight: 700;\n    cursor: pointer;\n\n    &:hover {\n        border-color: var(--chat-border-strong);\n        background: #f8fbfa;\n    }\n\n    &:disabled {\n        opacity: 0.55;\n        cursor: not-allowed;\n    }\n}\n\n.messageList {\n    flex: 1;\n    min-height: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    // Push scrollbar into the right gutter without shrinking content\n    padding-right: 12px;\n    margin-right: -12px;\n    overflow-y: auto;\n    scrollbar-width: thin;\n    scrollbar-color: #bed5cc transparent;\n}\n\n.messageListEmpty {\n    justify-content: flex-end;\n    padding-right: 0;\n    gap: 0;\n}\n\n.statusState {\n    padding: 14px 16px;\n    border: 1px dashed var(--chat-border-strong);\n    border-radius: 16px;\n    background: rgba(255, 255, 255, 0.7);\n    color: var(--chat-muted);\n    font-size: 13px;\n    line-height: 1.5;\n}\n\n.emptyState {\n    display: flex;\n    flex-direction: column;\n    align-items: stretch;\n    justify-content: flex-end;\n    gap: 4px;\n    width: 100%;\n    max-width: none;\n    margin: 0;\n    padding: 0;\n    color: var(--chat-text);\n    text-align: left;\n}\n\n.emptyStateIllustration {\n    display: block;\n    width: 177px;\n    max-width: 100%;\n    height: auto;\n    margin: 0 auto;\n}\n\n.emptyStateLead {\n    margin: 0;\n    width: 100%;\n    padding: 8px;\n    color: var(--chat-text);\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 22px;\n    white-space: pre-line;\n}\n\n.suggestionChips {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    width: 100%;\n    padding: 0 8px;\n}\n\n.suggestionChip {\n    display: inline-flex;\n    align-items: center;\n    justify-content: flex-start;\n    width: 100%;\n    min-height: 30px;\n    padding: 8px 12px;\n    border: 1px solid var(--chat-border);\n    border-radius: 8px;\n    background: var(--chat-surface);\n    color: var(--chat-text);\n    font-size: 13px;\n    font-weight: 400;\n    line-height: 18px;\n    text-align: left;\n    cursor: pointer;\n    transition: border-color 0.16s ease, background-color 0.16s ease;\n\n    &:hover {\n        border-color: var(--chat-border-strong);\n        background: var(--chat-surface-strong);\n        color: #2d3639;\n    }\n}\n\n.suggestionChipPrefix {\n    flex: 0 0 auto;\n    margin-right: 6px;\n    line-height: 1;\n}\n\n.suggestionChipCopy {\n    min-width: 0;\n}\n\n.messageGroup {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    width: 100%;\n}\n\n.messageCard {\n    --message-surface: #f5f7fc;\n    width: 100%;\n    border-radius: 16px;\n    background: var(--message-surface);\n    overflow: hidden;\n}\n\n.messageBody {\n    position: relative;\n    box-sizing: border-box;\n    padding: 12px 16px;\n    color: var(--chat-text);\n    font-size: 14px;\n    line-height: 22px;\n    word-break: break-word;\n    white-space: pre-wrap;\n    overflow-wrap: anywhere;\n    content-visibility: auto;\n    contain-intrinsic-size: auto 48px;\n}\n\n.assistantMessage {\n    --message-surface: #fff;\n    border-radius: 4px;\n}\n\n.userMessage {\n    --message-surface: #f5f7fc;\n}\n\n.assistantMessage .messageBody {\n    padding: 8px;\n    white-space: normal;\n}\n\n.messageBodyCollapsed {\n    max-height: 164px;\n    overflow: hidden;\n\n    &::after {\n        content: "";\n        position: absolute;\n        right: 0;\n        bottom: 0;\n        left: 0;\n        height: 88px;\n        background: linear-gradient(180deg, transparent 0%, var(--message-surface) 82%);\n        pointer-events: none;\n    }\n}\n\n.messageExpandButton {\n    width: 100%;\n    min-height: 36px;\n    padding: 8px 16px;\n    border: 0;\n    background: var(--message-surface);\n    color: #2d3639;\n    font-size: 12px;\n    font-weight: 600;\n    line-height: 20px;\n    text-align: left;\n    cursor: pointer;\n}\n\n.messageActions {\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    gap: 8px;\n    min-height: 32px;\n    width: fit-content;\n    margin-left: auto;\n}\n\n.messageTime {\n    color: var(--chat-muted);\n    font-size: 12px;\n    font-weight: 500;\n    line-height: 20px;\n}\n\n.modelLabel {\n    color: #7c8187;\n    font-size: 10px;\n    font-weight: 500;\n    line-height: 20px;\n    padding: 1px 6px;\n    border-radius: 4px;\n    background: rgba(124, 129, 135, 0.1);\n}\n\n.messageActionButton {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    border: 0;\n    border-radius: 4px;\n    background: transparent;\n    color: var(--chat-subtext);\n    cursor: pointer;\n    padding: 0;\n    position: relative;\n    transition: background 0.18s ease, color 0.18s ease;\n\n    &:hover {\n        color: var(--chat-muted);\n    }\n}\n\n.copyActionButtonCopied {\n    color: #5f4dc7;\n}\n\n.copyIconStack {\n    position: relative;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 16px;\n    height: 16px;\n}\n\n.copyIconDefault,\n.copyIconSuccess {\n    position: absolute;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    inset: 0;\n    transform-origin: center;\n}\n\n.copyIconDefault {\n    opacity: 1;\n    transform: translateY(0) scale(1) rotate(0deg);\n}\n\n.copyIconSuccess {\n    color: #5f4dc7;\n    opacity: 0;\n    transform: translateY(2px) scale(0.72) rotate(8deg);\n}\n\n.actionIconGlyph,\n.statusIconGlyph,\n.thinkingGlyph,\n.sendIconGlyph {\n    display: block;\n    width: 16px;\n    height: 16px;\n    font-size: 16px;\n    line-height: 1;\n}\n\n.assistantStatusRow {\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    gap: 8px;\n    width: 100%;\n    min-height: 24px;\n    padding: 8px 8px 0;\n    color: var(--chat-subtext);\n}\n\n.assistantStatusRowSynthesis {\n    color: #76747a;\n}\n\n.assistantStatusLabel {\n    flex: 1;\n    min-width: 0;\n    color: inherit;\n    font-size: 12px;\n    font-weight: 500;\n    line-height: 20px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n.assistantStatusIcon {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    color: inherit;\n}\n\n.assistantStatusIconLeading {\n    display: inline-flex;\n    align-items: flex-start;\n    justify-content: center;\n    flex-shrink: 0;\n    width: 16px;\n    height: 20px;\n    color: inherit;\n}\n\n.assistantStatusIconLeading.active {\n    animation: thinkPulse 1.6s ease-in-out infinite;\n}\n\n.synthesisGlyph {\n    display: block;\n    width: 16px;\n    height: 16px;\n    line-height: 1;\n}\n\n.synthesisCard {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 4px;\n    width: 100%;\n    padding: 8px;\n    border: 1px solid #e4e4e4;\n    border-radius: 8px;\n    background: #fff;\n}\n\n.synthesisBody {\n    width: 100%;\n    margin: 0;\n    padding: 0 4px 4px;\n    color: #384347;\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 22px;\n    word-break: break-word;\n    overflow-wrap: anywhere;\n}\n\n.markdown {\n    p {\n        margin: 0 0 8px;\n        font-size: inherit;\n        line-height: inherit;\n\n        &:last-child {\n            margin-bottom: 0;\n        }\n    }\n\n    ul,\n    ol {\n        margin: 6px 0 8px;\n        padding-left: 18px;\n        font-size: inherit;\n    }\n\n    li {\n        margin-bottom: 3px;\n\n        p {\n            margin: 0;\n        }\n    }\n\n    strong {\n        font-weight: 700;\n    }\n\n    code {\n        padding: 2px 5px;\n        border-radius: 6px;\n        background: #f1f5f3;\n        font-size: 0.92em;\n        font-family: monospace;\n    }\n\n    pre {\n        margin: 8px 0;\n        padding: 10px 12px;\n        border-radius: 10px;\n        background: #f4f7f5;\n        overflow-x: auto;\n\n        code {\n            padding: 0;\n            background: none;\n        }\n    }\n\n    h1,\n    h2,\n    h3 {\n        margin: 8px 0 4px;\n        font-size: inherit;\n        font-weight: 700;\n    }\n\n    blockquote {\n        margin: 6px 0 8px;\n        padding-left: 10px;\n        border-left: 3px solid #d2e4dd;\n        color: #5b6a66;\n        font-size: inherit;\n    }\n\n    > *:first-child {\n        margin-top: 0;\n    }\n\n    > *:last-child {\n        margin-bottom: 0;\n    }\n}\n\n.thinkingStart {\n    display: flex;\n    align-items: center;\n    width: 100%;\n    min-height: 28px;\n    padding: 4px 8px 8px;\n}\n\n.thinkingDot {\n    width: 12px;\n    height: 12px;\n    border-radius: 999px;\n    background: #2dc08d;\n    transform-origin: center;\n    animation: thinkingDotPulse 1.4s ease-in-out infinite;\n}\n\n.thinkingBlock {\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n}\n\n.thinkingHeader {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    width: 100%;\n    padding: 8px 8px 0;\n}\n\n.thinkingIcon {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 16px;\n    height: 16px;\n    color: #afb4b5;\n}\n\n.thinkingIcon.active {\n    animation: thinkPulse 1.6s ease-in-out infinite;\n}\n\n@keyframes thinkPulse {\n    0%,\n    100% {\n        opacity: 0.65;\n        transform: scale(1);\n    }\n\n    50% {\n        opacity: 1;\n        transform: scale(1.08);\n    }\n}\n\n@keyframes thinkingDotPulse {\n    0%,\n    100% {\n        transform: scale(1);\n    }\n\n    50% {\n        transform: scale(1.333);\n    }\n}\n\n.thinkingTitle {\n    flex: 1;\n    min-width: 0;\n    color: #afb4b5;\n    font-size: 12px;\n    font-weight: 500;\n    line-height: 20px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n    animation: thinkingFadeIn 0.3s ease-in-out;\n}\n\n.thinkingSkeleton {\n    width: 100%;\n    padding-bottom: 8px;\n}\n\n.thinkingSkeletonBar {\n    display: block;\n    width: 100%;\n    max-width: 256px;\n    height: 28px;\n    border-radius: 999px;\n    background: linear-gradient(90deg, #eef2f5 0%, #f8fafb 45%, #eef2f5 100%);\n    background-size: 200% 100%;\n    animation: thinkingShimmer 1.6s linear infinite;\n}\n\n@keyframes thinkingShimmer {\n    0% {\n        background-position: 200% 0;\n    }\n\n    100% {\n        background-position: -200% 0;\n    }\n}\n\n@keyframes thinkingFadeIn {\n    0% {\n        opacity: 0;\n        transform: translateY(2px);\n    }\n\n    100% {\n        opacity: 1;\n        transform: translateY(0);\n    }\n}\n\n.cursor {\n    display: inline-block;\n    width: 2px;\n    height: 1em;\n    margin-left: 2px;\n    background: currentColor;\n    vertical-align: text-bottom;\n    animation: blink 0.8s step-end infinite;\n}\n\n@keyframes blink {\n    0%,\n    100% {\n        opacity: 1;\n    }\n\n    50% {\n        opacity: 0;\n    }\n}\n\n.feedbackRow {\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    width: 100%;\n    padding: 0 8px;\n}\n\n.feedbackActions {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    height: 32px;\n}\n\n.feedbackButton {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    padding: 8px;\n    border: 1px solid transparent;\n    border-radius: 4px;\n    background: transparent;\n    color: var(--chat-subtext);\n    cursor: pointer;\n    overflow: visible;\n    position: relative;\n    transition: color 0.14s ease, background-color 0.14s ease, border-color 0.14s ease;\n\n    &:hover {\n        border-color: transparent;\n        background: transparent;\n        color: var(--chat-muted);\n    }\n}\n\n.feedbackButton.feedbackActive {\n    color: #5f4dc7;\n}\n\n.feedbackIconWrapper {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.feedbackBurstRing {\n    position: absolute;\n    inset: 0;\n    border: 2px solid #e3e0f6;\n    border-radius: 50%;\n    opacity: 0;\n    pointer-events: none;\n}\n\n.feedbackBurstParticle {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 3px;\n    height: 3px;\n    margin: -1.5px 0 0 -1.5px;\n    border-radius: 50%;\n    background: #5f4dc7;\n    opacity: 0;\n    pointer-events: none;\n}\n\n.responseInfoMenuWrapper {\n    position: relative;\n    display: inline-flex;\n}\n\n.responseInfoMenu {\n    position: fixed;\n    z-index: 10000;\n    width: 232px;\n    padding: 10px;\n    border: 1px solid #e4e4e4;\n    border-radius: 12px;\n    background: #fff;\n    box-shadow: 0 14px 28px rgba(45, 54, 57, 0.14);\n}\n\n.responseInfoActions {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 6px;\n}\n\n.responseInfoAction {\n    min-height: 30px;\n    padding: 4px 8px;\n    border: 1px solid #e4e4e4;\n    border-radius: 8px;\n    background: #fff;\n    color: var(--chat-text);\n    font-size: 12px;\n    font-weight: 500;\n    line-height: 18px;\n    cursor: pointer;\n\n    &:hover {\n        border-color: var(--chat-border);\n        background: #f8fafc;\n    }\n\n    &:disabled {\n        opacity: 0.55;\n        cursor: not-allowed;\n    }\n}\n\n.responseInfoDivider {\n    width: 100%;\n    height: 1px;\n    margin: 10px 0;\n    background: #eef0f1;\n}\n\n.responseInfoRow {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 12px;\n    padding: 4px 2px;\n    color: var(--chat-text);\n    font-size: 12px;\n    line-height: 18px;\n\n    span:first-child {\n        flex: 0 0 auto;\n        color: var(--chat-muted);\n    }\n\n    span:last-child {\n        min-width: 0;\n        max-width: 118px;\n        font-weight: 500;\n        text-align: right;\n        overflow-wrap: anywhere;\n    }\n}\n\n.contextClearedBanner {\n    border: 1px solid var(--chat-warning-border);\n    border-radius: 14px;\n    background: var(--chat-warning-bg);\n    color: #8f6510;\n    font-size: 12px;\n    line-height: 1.45;\n    box-shadow: 0 6px 18px rgba(143, 101, 16, 0.08);\n    gap: 6px;\n}\n\n.loadConversationErrorStrip {\n    justify-content: space-between;\n    gap: 8px;\n    border: 1px solid #f0c2c2;\n    border-radius: 12px;\n    background: #fdecec;\n    color: #9a3a3a;\n    font-size: 12px;\n    line-height: 1.45;\n}\n\n.loadConversationErrorMessage {\n    flex: 1;\n    min-width: 0;\n}\n\n.loadConversationErrorRetry {\n    flex-shrink: 0;\n    padding: 4px 10px;\n    border: 1px solid #d99a9a;\n    border-radius: 8px;\n    background: #fff;\n    color: #9a3a3a;\n    font-size: 12px;\n    font-weight: 600;\n    cursor: pointer;\n\n    &:hover {\n        border-color: #c58383;\n        background: #fff4f4;\n    }\n}\n\n.messageQueue {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    padding: 8px 12px;\n    border: 1px solid var(--chat-border);\n    border-radius: 12px;\n    background: #f5f7fc;\n    font-size: 12px;\n}\n\n.messageQueueLabel {\n    color: var(--chat-muted);\n    font-weight: 600;\n    font-size: 11px;\n    text-transform: uppercase;\n    letter-spacing: 0.4px;\n}\n\n.messageQueueItem {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n    padding: 4px 0;\n}\n\n.messageQueueText {\n    flex: 1;\n    overflow: hidden;\n    color: var(--chat-text);\n    text-overflow: ellipsis;\n    white-space: nowrap;\n}\n\n.messageQueueRemove {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    width: 20px;\n    height: 20px;\n    padding: 0;\n    border: 0;\n    border-radius: 4px;\n    background: transparent;\n    color: var(--chat-muted);\n    font-size: 12px;\n    cursor: pointer;\n\n    &:hover {\n        background: rgba(0, 0, 0, 0.06);\n        color: var(--chat-text);\n    }\n}\n\n.inputArea {\n    display: flex;\n    flex-direction: column;\n    align-items: stretch;\n    gap: 16px;\n    box-sizing: border-box;\n    padding: 16px;\n    border: 1px solid var(--chat-border);\n    border-radius: 8px;\n    background: #fff;\n    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.05);\n}\n\n.inputAreaConversation {\n    gap: 24px;\n}\n\n.input {\n    width: 100%;\n    min-height: 22px;\n    max-height: 140px;\n    padding: 0;\n    border: 0;\n    background: transparent;\n    color: var(--chat-input-text);\n    font-family: inherit;\n    font-size: 14px;\n    line-height: 22px;\n    resize: none;\n    overflow-y: hidden;\n    outline: none;\n    transition: height 0.1s ease-out;\n\n    &::placeholder {\n        color: var(--chat-muted);\n    }\n}\n\n.inputActions {\n    display: flex;\n    flex-direction: row;\n    align-items: flex-end;\n    justify-content: flex-end;\n    gap: 6px;\n}\n\n.inputHint {\n    display: none;\n}\n\n.sendButton {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 32px;\n    height: 32px;\n    padding: 8px;\n    border: 0;\n    border-radius: 50px;\n    background: #2dc08d;\n    color: #fff;\n    cursor: pointer;\n    box-shadow: none;\n\n    &:hover {\n        background: #29b180;\n    }\n\n    &:disabled {\n        cursor: not-allowed;\n        background: var(--chat-subtext);\n        opacity: 1;\n    }\n}\n\n@media (max-width: 520px) {\n    .container {\n        gap: 16px;\n        padding: 16px;\n    }\n\n    .header {\n        padding: 0;\n    }\n\n    .inputArea {\n        padding: 16px;\n    }\n\n    .subtitle {\n        max-width: none